<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:id="@+id/topAllAttachmentsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvAllAttachmentsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All Attachments"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAllAttachmentsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Images, files and links from all unlocked notes"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/allAttachmentsScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topAllAttachmentsSection"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/allAttachmentsContentSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvAllAttachmentsCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_note_input"
                android:padding="16dp"
                android:text="0 attachment(s)"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAllImagesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="Images"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewImageFilters"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="24dp"
                android:paddingEnd="14dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAllAttachmentImages"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="8dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyAllAttachmentImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="No images found."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvAllFilesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="Files"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewFileFilters"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="24dp"
                android:paddingEnd="14dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAllAttachmentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyAllAttachmentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="No files found."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvAllLinksTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="Links"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewLinkFilters"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="24dp"
                android:paddingEnd="14dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAllAttachmentLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyAllAttachmentLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="No links found."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </ScrollView>

</RelativeLayout>