<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Top Section -->
    <RelativeLayout
        android:id="@+id/topCategoriesSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/categoriesTitleSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnSortCategories"
            android:layout_alignParentStart="true"
            android:orientation="vertical"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvCategoriesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCategoriesSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organize your notes"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnSortCategories"
            android:layout_width="82dp"
            android:layout_height="42dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/categoriesTitleSection"
            android:background="@drawable/bg_note_input"
            android:gravity="center"
            android:text="Sort"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

    <!-- New Category Button -->
    <TextView
        android:id="@+id/btnNewCategory"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/topCategoriesSection"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_create_note_button"
        android:gravity="center"
        android:text="+ New Category"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

    <!-- Category List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewCategories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnNewCategory"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        android:clipToPadding="false" />

    <!-- Empty Message -->
    <TextView
        android:id="@+id/tvEmptyCategories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No categories yet.\nCreate your first category."
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_centerInParent="true" />

</RelativeLayout>