<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Top Section -->
    <LinearLayout
        android:id="@+id/topCategoryNotesSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvCategoryNotesTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCategoryNotesSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notes in this category"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Notes List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewCategoryNotes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topCategoryNotesSection"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        android:clipToPadding="false" />

    <!-- Empty Notes Message -->
    <TextView
        android:id="@+id/tvEmptyCategoryNotes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No notes in this category."
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_centerInParent="true" />

</RelativeLayout>