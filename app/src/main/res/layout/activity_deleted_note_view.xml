<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:id="@+id/topDeletedViewSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvDeletedViewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deleted Note"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDeletedViewSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recover this note before editing"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/deletedNoteScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topDeletedViewSection"
        android:layout_above="@id/deletedBottomButtonSection"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/deletedNoteInputSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp">

            <EditText
                android:id="@+id/etDeletedNoteTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_note_input"
                android:hint="Note title"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/etDeletedNoteContent"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_note_input"
                android:gravity="top"
                android:hint="Note content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="8"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"

                android:textColorLink="@color/primary_blue"

                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDeletedAttachedImagesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Attached Images"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewDeletedNoteImages"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyDeletedImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No images attached."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDeletedAttachedFilesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Attached Files"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewDeletedNoteFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyDeletedFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No files attached."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/deletedBottomButtonSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="22dp">

        <TextView
            android:id="@+id/btnRecoverNote"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_create_note_button"
            android:gravity="center"
            android:text="Recover Note"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDeleteForever"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_delete_note_button"
            android:gravity="center"
            android:text="Delete Forever"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</RelativeLayout>