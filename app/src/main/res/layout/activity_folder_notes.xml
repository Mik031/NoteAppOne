<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Top Section -->
    <LinearLayout
        android:id="@+id/topFolderNotesSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvFolderNotesTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Folder"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFolderNotesSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notes in this folder"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Add Notes Button -->
    <TextView
        android:id="@+id/btnAddNotesToFolder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/topFolderNotesSection"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_create_note_button"
        android:gravity="center"
        android:text="+ Add Notes"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

    <!-- Notes List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewFolderNotes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnAddNotesToFolder"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        android:clipToPadding="false" />

    <!-- Empty Notes Message -->
    <TextView
        android:id="@+id/tvEmptyFolderNotes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No notes in this folder."
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_centerInParent="true" />

</RelativeLayout>