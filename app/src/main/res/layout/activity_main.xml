<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tasks"
        android:textColor="@color/text_main"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/taskInputCard"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <EditText
                android:id="@+id/etTask"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:background="@null"
                android:hint="New task"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:textColor="@color/text_main"
                android:textColorHint="@color/accent_blue"
                android:textSize="28sp"
                android:textStyle="bold"
                android:singleLine="true"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_main"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="67dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipHigh"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/chip_high"
                            android:drawableStart="@drawable/ic_flag"
                            android:drawablePadding="6dp"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="High"
                            android:textColor="#EF4444"/>

                        <TextView
                            android:id="@+id/chipMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/chip_medium"
                            android:drawableStart="@drawable/ic_flag"
                            android:drawablePadding="6dp"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Medium"
                            android:textColor="#F59E0B"/>

                        <TextView
                            android:id="@+id/chipLow"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/chip_low"
                            android:drawableStart="@drawable/ic_flag"
                            android:drawablePadding="6dp"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Low"
                            android:textColor="#10B981"/>

                    </LinearLayout>

                </HorizontalScrollView>

                <ImageButton
                    android:id="@+id/btnDueDate"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/pill_bg"
                    android:contentDescription="Due Date"
                    android:padding="12dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/accent_blue" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTasks"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/taskInputCard"
        app:layout_constraintBottom_toTopOf="@id/btnAdd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/btnAdd"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/circle_accent"
        android:contentDescription="Add Task"
        android:padding="20dp"
        android:src="@drawable/ic_check"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/surface_card" />

    <ImageButton
        android:id="@+id/btnExpenseScreen"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/pill_surface"
        android:src="@android:drawable/ic_menu_manage"
        android:contentDescription="Expenses"
        app:layout_constraintTop_toTopOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/accent_blue" />

</androidx.constraintlayout.widget.ConstraintLayout>
