<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:id="@+id/topAttachmentsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvAttachmentsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attachments"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAttachmentsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Images, files and links from this note"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/attachmentsScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topAttachmentsSection"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/attachmentsContentSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvAttachmentNoteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_note_input"
                android:padding="16dp"
                android:text="Note title"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvAllAttachmentsCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 attachment(s)"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvImagesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Images"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAttachmentImages"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyAttachmentImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No images attached."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvFilesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Files"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAttachmentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyAttachmentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No files attached."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvLinksTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Links"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAttachmentLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmptyAttachmentLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No links attached."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </ScrollView>

</RelativeLayout>