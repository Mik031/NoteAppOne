<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Settings"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose what appears inside note preview cards"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginBottom="28dp" />

        <LinearLayout
            android:id="@+id/btnImagePreview"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_home_card"
            android:padding="18dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🖼 Image Preview"
                    android:textColor="@color/text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show latest images on note cards"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="5dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvImagePreviewStatus"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:background="@drawable/bg_note_input"
                android:text="On"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnFilePreview"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_home_card"
            android:padding="18dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📎 File Preview"
                    android:textColor="@color/text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show latest files on note cards"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="5dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvFilePreviewStatus"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:background="@drawable/bg_note_input"
                android:text="On"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnLinkPreview"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_home_card"
            android:padding="18dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔗 Link Preview"
                    android:textColor="@color/text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show latest links on note cards"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="5dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvLinkPreviewStatus"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:background="@drawable/bg_note_input"
                android:text="On"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn all three off to show no attachment previews on note cards."
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>