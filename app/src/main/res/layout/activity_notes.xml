<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- MAIN NOTES PAGE -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_background">

        <RelativeLayout
            android:id="@+id/topSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="24dp"
            android:paddingTop="70dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/btnOpenDrawer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_alignTop="@id/titleSection"
                android:background="@drawable/bg_note_input"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="☰"
                android:textColor="@color/text_primary"
                android:textSize="23sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/titleSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btnOpenDrawer"
                android:layout_toStartOf="@id/topRightButtonSection"
                android:layout_alignParentTop="true"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/tvNotesTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All Notes"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNotesSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Your saved notes"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/topRightButtonSection"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@id/titleSection"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnSortNotes"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_note_input"
                    android:clickable="true"
                    android:contentDescription="Sort notes"
                    android:focusable="true"
                    android:padding="10dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_sort_lines" />

                <ImageButton
                    android:id="@+id/btnPreviewSettings"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="15dp"
                    android:background="@drawable/bg_note_input"
                    android:clickable="true"
                    android:contentDescription="Preview settings"
                    android:focusable="true"
                    android:padding="10dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_attachment" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="15dp"
                    android:background="@drawable/bg_note_input"
                    android:clickable="true"
                    android:contentDescription="Settings"
                    android:focusable="true"
                    android:padding="10dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_settings" />

            </LinearLayout>

        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewCategoryFilters"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_below="@id/topSection"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="14dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewNotes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/recyclerViewCategoryFilters"
            android:clipToPadding="false"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="100dp" />

        <TextView
            android:id="@+id/tvEmptyNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:text="No notes yet.\nCreate your first note."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnCreateNote"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_create_note_button"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- LEFT SIDEBAR MENU -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/app_background"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="70dp">

        <TextView
            android:id="@+id/tvDrawerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NoteApp UX"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Organize your notes"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="18dp"
            android:background="@color/text_secondary"
            android:alpha="0.25" />

        <TextView
            android:id="@+id/btnDrawerNotes"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_note_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:paddingStart="16dp"
            android:text="📝  Notes"
            android:textColor="@color/primary_blue"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDrawerSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_note_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:text="🔍  Search"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDrawerCategories"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_note_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:text="🏷  Categories"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDrawerFolders"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_note_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:text="📁  Folders"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDrawerRecentlyDeleted"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_note_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:text="🗑  Recently Deleted"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>