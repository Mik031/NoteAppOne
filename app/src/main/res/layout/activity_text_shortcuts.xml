<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <RelativeLayout
        android:id="@+id/topTextShortcutsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/textShortcutTitleSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnSortTextShortcuts"
            android:layout_alignParentStart="true"
            android:orientation="vertical"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvTextShortcutsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Text Shortcuts"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTextShortcutsSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Expand note shortcuts inside other apps"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnSortTextShortcuts"
            android:layout_width="82dp"
            android:layout_height="42dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/textShortcutTitleSection"
            android:background="@drawable/bg_note_input"
            android:gravity="center"
            android:text="Sort"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

    <TextView
        android:id="@+id/tvShortcutPermissionInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topTextShortcutsSection"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_note_input"
        android:padding="16dp"
        android:text="This feature uses Android Accessibility permission to detect shortcuts you type, like /dd, and replace them with your saved note content. Locked notes are not used for shortcuts."
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/btnEnableShortcutService"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/tvShortcutPermissionInfo"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_create_note_button"
        android:gravity="center"
        android:text="Enable Shortcut Service"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTextShortcuts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnEnableShortcutService"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/tvEmptyTextShortcuts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No text shortcuts yet.\nOpen a note and add a shortcut like /dd."
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_centerInParent="true" />

</RelativeLayout>