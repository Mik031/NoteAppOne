<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/deletedNoteRootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp">

    <!-- Hidden Right Side Buttons -->
    <LinearLayout
        android:id="@+id/deletedNoteActionLayout"
        android:layout_width="170dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:id="@+id/btnRecoverDeletedNote"
            android:layout_width="85dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@color/primary_blue"
            android:text="Recover"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDeleteForeverNote"
            android:layout_width="85dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@color/danger_red"
            android:text="Delete"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Main Deleted Note Card -->
    <LinearLayout
        android:id="@+id/deletedNoteItemLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_note_card"
        android:padding="18dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvDeletedNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deleted Note Title"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvDeletedNoteContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deleted note preview text..."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvDeletedNoteDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="26 May 2026"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</FrameLayout>