<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/folderRootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp">

    <!-- Hidden Right Side Buttons -->
    <LinearLayout
        android:id="@+id/folderActionLayout"
        android:layout_width="150dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:id="@+id/btnEditFolder"
            android:layout_width="75dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@color/primary_blue"
            android:text="Edit"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDeleteFolder"
            android:layout_width="75dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@color/danger_red"
            android:text="Delete"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Main Folder Card -->
    <LinearLayout
        android:id="@+id/folderItemLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_note_card"
        android:padding="18dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvFolderIcon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="📁"
            android:textSize="24sp"
            android:background="@drawable/bg_category_icon" />

        <TextView
            android:id="@+id/tvFolderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="Folder Name"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvFolderArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="@color/text_hint"
            android:textSize="30sp" />

    </LinearLayout>

</FrameLayout>