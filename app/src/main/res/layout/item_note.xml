<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/noteRootContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvNoteSectionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pinned"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp" />

    <FrameLayout
        android:id="@+id/noteRootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/notePinActionLayout"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/btnSwipePinNote"
                android:layout_width="70dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_swipe_action_primary"
                android:clickable="true"
                android:contentDescription="Pin note"
                android:focusable="true"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_pin" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/noteActionLayout"
            android:layout_width="170dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="6dp"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/btnShareNote"
                android:layout_width="74dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_swipe_action_primary"
                android:clickable="true"
                android:contentDescription="Share note"
                android:focusable="true"
                android:padding="28dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_share" />

            <ImageButton
                android:id="@+id/btnDeleteSwipeNote"
                android:layout_width="74dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_swipe_action_danger"
                android:clickable="true"
                android:contentDescription="Delete note"
                android:focusable="true"
                android:padding="28dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_delete" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/noteItemLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_note_card"
            android:padding="18dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvNoteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Note Title"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvNoteContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is the note preview text..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <LinearLayout
                android:id="@+id/layoutNoteImagePreview"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgNotePreview1"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_marginEnd="8dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_note_input"
                    android:contentDescription="Note image preview 1" />

                <ImageView
                    android:id="@+id/imgNotePreview2"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_marginEnd="8dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_note_input"
                    android:contentDescription="Note image preview 2" />

                <ImageView
                    android:id="@+id/imgNotePreview3"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_note_input"
                    android:contentDescription="Note image preview 3" />

            </LinearLayout>

            <!-- Latest 3 File Preview Row -->
            <LinearLayout
                android:id="@+id/layoutNoteFilePreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvFilePreview1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_note_input"
                    android:padding="8dp"
                    android:text="📎 file.pdf"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvFilePreview2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_note_input"
                    android:padding="8dp"
                    android:text="📎 file.docx"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvFilePreview3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_note_input"
                    android:padding="8dp"
                    android:text="📎 file.zip"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Latest 3 Link Preview Row -->
            <LinearLayout
                android:id="@+id/layoutNoteLinkPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvLinkPreview1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_note_input"
                    android:padding="8dp"
                    android:text="🔗 https://example.com"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvLinkPreview2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_note_input"
                    android:padding="8dp"
                    android:text="🔗 https://example.com"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvLinkPreview3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_note_input"
                    android:padding="8dp"
                    android:text="🔗 https://example.com"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvNoteDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="26 May 2026"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>