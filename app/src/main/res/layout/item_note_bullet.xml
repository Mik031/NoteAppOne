<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bulletItemLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:background="@drawable/bg_note_input"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/btnDragBullet"
        android:layout_width="32dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="≡"
        android:textColor="@color/text_secondary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/btnBulletCompleted"
        android:layout_width="34dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="☐"
        android:textColor="@color/primary_blue"
        android:textSize="20sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/tvBulletSymbol"
        android:layout_width="38dp"
        android:layout_height="wrap_content"
        android:text="•"
        android:textColor="@color/primary_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/tvBulletText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Bullet point text"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:lineSpacingExtra="2dp"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/btnDeleteBullet"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="×"
        android:textColor="@color/white"
        android:textSize="21sp"
        android:textStyle="bold"
        android:background="@color/danger_red"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>